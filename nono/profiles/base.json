{
  "$schema": "../nono-profile.schema.json",
  "meta": {
    "name": "base"
  },
  "extends": [
    "default"
  ],
  "groups": {
    "include": [
      "git_config",
      "go_runtime",
      "user_caches_linux",
      "user_caches_macos"
    ]
  },
  "filesystem": {
    "allow": [
      "~/.config/nono/profile-drafts",
      "~/go/pkg/mod/cache"
    ],
    "read": [
      "~/.agents/skills",
      "~/.config/nono/packages",
      "~/.config/nono/profiles",
      "~/.local/share/mise/installs"
    ],
    "read_file": [
      "~/.gitconfig.private"
    ]
  },
  "workdir": {
    "access": "readwrite"
  }
}
